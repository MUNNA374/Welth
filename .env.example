# Welth Environment Configuration Template

# FastAPI config
ENVIRONMENT=development
SECRET_KEY=SUPER_SECRET_SECURITY_KEY_FOR_JWT_WELTH_2026_DO_NOT_LEAK
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Databases
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/welth
REDIS_URL=redis://localhost:6379/0

# Google Gemini AI Key (Required for AI Chat & OCR advice)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# AWS S3 Storage parameters (optional, defaults to local folder uploads)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET_NAME=YOUR_S3_BUCKET_NAME

# Cloudinary parameters (optional, defaults to local folder uploads)
CLOUDINARY_URL=cloudinary://YOUR_CLOUDINARY_API_KEY:YOUR_CLOUDINARY_API_SECRET@YOUR_CLOUD_NAME

# Sentry Monitoring parameters (optional)
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
